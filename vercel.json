{
    "buildCommand": "cd frontend && npm install && npm run build",
    "installCommand": "cd frontend && npm install",
    "experimentalServices": {
        "frontend": {
            "entrypoint": "frontend",
            "routePrefix": "/",
            "framework": "create-react-app"
        },
        "backend": {
            "entrypoint": "backend",
            "routePrefix": "/_/backend"
        }
    }
}